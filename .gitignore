# Build outputs — everything in build/ is regeneratable, except the canonical PDF.
build/*
!build/main.pdf

# Other PDFs
*.pdf
**/*.pdf
!build/main.pdf

# Ignore Typst build caches
.typst/

# Rust target dir (left over from cargo install)
target/

# Ignore editor-specific files
*.swp              # Vim/Neovim swap files
*.swo              # Vim/Neovim swap files
*.bak              # Backup files
*.~*               # Temporary files
.idea/             # JetBrains IDEs (e.g., PyCharm)
.vscode/           # VS Code
*.code-workspace   # VS Code workspace files

# Ignore system-specific files
.DS_Store          # macOS
Thumbs.db          # Windows
desktop.ini        # Windows

# Ignore virtual environments
**/.venv/

# Ignore log files
*.log
