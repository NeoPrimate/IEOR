// Semantic color palette. Use these names in new code so a re-theme is one edit
// instead of grepping #red / #blue / etc.
//
// Intent (current mapping shown in parens):
//   highlight  — what changes between derivation steps        (red)
//   focus      — the current variable / object of attention   (blue)
//   accent     — secondary emphasis                            (orange)
//   support    — tertiary emphasis                             (purple)
//   ok         — correct / converged / valid                   (green)
//   muted      — de-emphasized but still visible              (gray)

#let highlight = red
#let focus     = blue
#let accent    = orange
#let support   = purple
#let ok        = green
#let muted     = gray
